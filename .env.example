# LinkedIn Social Listening Pipeline - Environment Variables
# Copy this file to .env and fill in your values
# These are NOT used by n8n directly - they're a reference for the placeholders in the workflow JSON

# Apify
APIFY_TOKEN=your_apify_api_token_here

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_from_url

# OpenRouter (LLM)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ClickUp
CLICKUP_API_TOKEN=your_clickup_personal_api_token
CLICKUP_WORKSPACE_ID=your_workspace_id
CLICKUP_CHANNEL_ID=your_chat_channel_id

# Twilio
TWILIO_ACCOUNT_SID=your_account_sid_starting_with_AC
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
YOUR_PHONE_NUMBER=+1XXXXXXXXXX
